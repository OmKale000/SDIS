{
    "manifest_version": 3,
    "name": "SDIS Sentinel - Advanced Privacy Guard",
    "version": "1.2",
    "description": "Real-time sensitive data input monitoring, clipboard sentinel, and one-tap privacy cleanup.",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon512.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon512.png"
        }
    },
    "permissions": [
        "storage",
        "activeTab",
        "cookies",
        "browsingData",
        "notifications",
        "alarms"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "service_worker.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content/content.js"],
            "run_at": "document_idle"
        }
    ]
}
